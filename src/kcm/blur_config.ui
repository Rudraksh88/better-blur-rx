     <widget class="QWidget">
      <attribute name="title">
       <string>Window Overrides</string>
      </attribute>
      <layout class="QVBoxLayout">
       <item>
        <layout class="QHBoxLayout">
         <item>
          <widget class="QLabel" name="windowOverridesBriefDescription">
           <property name="text">
            <string>Override blur settings for specific windows. Rules are checked top to bottom; the first matching rule wins.</string>
           </property>
           <property name="wordWrap">
            <bool>true</bool>
           </property>
           <property name="sizePolicy">
            <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
